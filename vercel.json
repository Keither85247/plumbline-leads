{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*",  "destination": "https://plumbline-leads.onrender.com/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://plumbline-leads.onrender.com/auth/:path*" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
