# ── Backend environment variables ─────────────────────────────────────────────
# Copy this file to backend/.env and fill in real values.
# Never commit .env — it is gitignored.

# Server
PORT=3001
NODE_ENV=development

# Database
# Leave unset for local dev (uses backend/leads.db).
# On Render, set to /data/leads.db (persistent disk mount).
# DB_PATH=/data/leads.db

# Frontend origin (used for CORS and OAuth redirects).
# In production: set to your Vercel deployment URL, e.g. https://plumbline.vercel.app
# In local dev: leave unset (CORS allows all; OAuth redirects to localhost:5173)
FRONTEND_URL=http://localhost:5173

# OpenAI — used for transcription (Whisper) and lead summarisation (GPT-4o)
OPENAI_API_KEY=sk-...

# Twilio
# TWILIO_BASE_URL must be the publicly reachable root URL of your backend.
# In production: https://<your-render-service>.onrender.com
# In local dev: your ngrok tunnel URL, e.g. https://xyz.ngrok-free.app
TWILIO_BASE_URL=https://your-backend.onrender.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTRACTOR_PHONE_NUMBER=+1xxxxxxxxxx

# Google OAuth (Gmail integration)
# Authorised redirect URI in Google Cloud Console must match GOOGLE_REDIRECT_URI exactly.
# In production: https://<your-render-service>.onrender.com/auth/google/callback
# In local dev:  http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
